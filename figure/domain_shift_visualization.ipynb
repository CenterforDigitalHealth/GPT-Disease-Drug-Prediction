        "\n",
        "inset_texts = []\n",
        "for g in clusters:\n",
        "    tips = np.array([[float(W[0, j] * arrow_scale), float(W[1, j] * arrow_scale)] for j in g])\n",
        "    wx = float(np.mean([float(W[0, j]) for j in g]))\n",
        "    wy = float(np.mean([float(W[1, j]) for j in g]))\n",
        "    wmn = float(np.hypot(wx, wy))\n",
        "    if wmn < 1e-12:\n",
        "        udir = np.array([1.0, 0.0])\n",
