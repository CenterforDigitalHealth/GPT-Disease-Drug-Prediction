        "_pb = ax.get_position()\n",
        "_INSET_FRAC = 0.44\n",
        "_INSET_PAD = 0.012\n",
        "_iw = _pb.width * _INSET_FRAC\n",
        "_ih = _pb.height * _INSET_FRAC\n",
        "_axinl = _pb.x1 - _iw - _INSET_PAD\n",
